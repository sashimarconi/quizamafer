{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/www.quizamazonopennow.com/assets/$1" },
    { "source": "/signals/(.*)", "destination": "/www.quizamazonopennow.com/signals/$1" },
    { "source": "/schema.org/(.*)", "destination": "/www.quizamazonopennow.com/schema.org/$1" },
    { "source": "/_flock.js", "destination": "/www.quizamazonopennow.com/_flock.js" },
    { "source": "/e.html", "destination": "/www.quizamazonopennow.com/e.html" },
    { "source": "/o.html", "destination": "/www.quizamazonopennow.com/o.html" },
    { "source": "/t.html", "destination": "/www.quizamazonopennow.com/t.html" },
    { "source": "/cdn.utmify.com.br/(.*)", "destination": "/cdn.utmify.com.br/$1" },
    { "source": "/connect.facebook.net/(.*)", "destination": "/connect.facebook.net/$1" },
    { "source": "/", "destination": "/www.quizamazonopennow.com/index.html" },
    { "source": "/(.*)", "destination": "/www.quizamazonopennow.com/index.html" }
  ]
}
