# Configure these in Vercel Project Settings -> Environment Variables
PARADISE_API_KEY=pk_live_replace_me
PARADISE_UPSELL_URL=https://example.com/upsell

# --- Optional settings below ---

# Server-side price rules (amount in cents) used to calculate total by kit + bumps + freight
PARADISE_PRICE_TABLE_JSON={"kits":{"bronze":2000,"prata":4000,"ouro":6000},"bumps":{"premium":990,"dobro":1990,"apple":2990},"freight":{"pac":1390,"sedex":1590,"express":2590}}

# Multi-product mode (recommended): key -> product hash + amount in cents
# Example keys: default, freight, bronze, prata, ouro
PARADISE_PRODUCTS_JSON={"default":{"productHash":"hash_default","amountCents":1000},"freight":{"productHash":"hash_frete","amountCents":1990}}

# Single-product fallback (optional)
PARADISE_PRODUCT_HASH=replace_product_hash
PARADISE_AMOUNT_CENTS=1000

# UTMify Orders API (backend)
UTMIFY_API_TOKEN=replace_utmify_api_token

# Optional
UTMIFY_PLATFORM=QuizAmazon
UTMIFY_IS_TEST=false
